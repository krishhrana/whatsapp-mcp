# Shared internal JWT secret (must match backend + bridge)
WHATSAPP_BRIDGE_JWT_SECRET=change-me
WHATSAPP_BRIDGE_JWT_ISSUER=omicron-api
WHATSAPP_INTERNAL_ALLOWED_SUBJECT_PREFIXES=omicron-api:,whatsapp-session-controller:

# Bridge HTTP API base URL
WHATSAPP_BRIDGE_API_BASE_URL=http://127.0.0.1:8080

# Runtime scope + message store settings
# - In ECS mode (WHATSAPP_RUNTIME_ECS_MODE=true), WHATSAPP_RUNTIME_USER_SCOPE is required and must be a UUID.
# - MCP reads from hot DB first: <WHATSAPP_MESSAGE_STORE_HOT_DIR>/users/<scope>/messages.db
# - Non-ECS local fallback reads persistent DB if hot DB is absent.
WHATSAPP_RUNTIME_USER_SCOPE=
WHATSAPP_RUNTIME_ECS_MODE=false
WHATSAPP_MESSAGE_STORE_MODE=hot_local_sync
WHATSAPP_MESSAGE_STORE_PERSISTENT_DIR=../whatsapp-bridge/store
WHATSAPP_MESSAGE_STORE_HOT_DIR=/tmp/whatsapp-store
WHATSAPP_MESSAGE_STORE_SYNC_INTERVAL_SECONDS=10

# MCP JWT validation requirements
WHATSAPP_MCP_JWT_AUDIENCE=whatsapp-mcp
WHATSAPP_MCP_REQUIRED_SCOPE=whatsapp:mcp
WHATSAPP_MCP_AUTH_ISSUER_URL=http://127.0.0.1:8000
WHATSAPP_MCP_RESOURCE_SERVER_URL=http://127.0.0.1:8000/mcp

# MCP server runtime
WHATSAPP_MCP_TRANSPORT=streamable-http
WHATSAPP_MCP_HOST=127.0.0.1
WHATSAPP_MCP_PORT=8000
WHATSAPP_MCP_STREAMABLE_HTTP_PATH=/mcp
WHATSAPP_MCP_MOUNT_PATH=/
